@{
    ViewData["Title"] = "Home";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Hero Section -->
<section class="sw-hero min-vh-100 d-flex align-items-center">
    <div class="container">
        <div class="row justify-content-center text-center">
            <div class="col-lg-7">
                <h1 class="sw-hero-title mb-4">
                    Your one-stop <span>smart shopping</span> resource
                </h1>
                <p class="text-muted fs-5 mb-5">
                    Thousands of products. One place. Delivered to your door.
                </p>
                @if (User.Identity!.IsAuthenticated)
                {
                    <a asp-controller="Catalog" asp-action="Index" class="btn btn-primary btn-lg px-5">
                        <i class="bi bi-grid me-2"></i>Browse Catalog
                    </a>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Register" class="btn btn-primary btn-lg px-5 me-3">
                        Get Started
                    </a>
                    <a asp-controller="Account" asp-action="Login" class="btn btn-outline-light btn-lg px-5">
                        Login
                    </a>
                }
            </div>
        </div>
    </div>
</section>