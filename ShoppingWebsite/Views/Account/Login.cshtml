@model ShoppingWebsite.ViewModels.Account.LoginVM
@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="min-vh-100 d-flex align-items-center justify-content-center py-5">
    <div class="sw-auth-card">
        <div class="text-center mb-4">
            <i class="bi bi-bag-heart-fill text-primary fs-1"></i>
            <h2 class="fw-bold mt-2">Welcome back</h2>
            <p class="text-muted small">Sign in to your ShopWave account</p>
        </div>

        <form asp-action="Login" method="post">
            <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
            @Html.AntiForgeryToken()

            <div class="sw-field mb-3">
                <label asp-for="Email" class="form-label small text-muted"></label>
                <input asp-for="Email" class="form-control sw-form-control" placeholder="you@example.com" />
                <span asp-validation-for="Email" class="field-error"></span>
            </div>

            <div class="sw-field mb-4">
                <label asp-for="Password" class="form-label small text-muted"></label>
                <input asp-for="Password" class="form-control sw-form-control" placeholder="••••••••" />
                <span asp-validation-for="Password" class="field-error"></span>
            </div>

            <div class="mb-4 d-flex justify-content-between align-items-center">
                <div class="form-check">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label asp-for="RememberMe" class="form-check-label small text-muted"></label>
                </div>
            </div>

            @if (!ViewData.ModelState.IsValid && ViewData.ModelState
                        .Any(x => x.Key == string.Empty && x.Value!.Errors.Count > 0))
            {
                <div class="alert alert-danger py-2 small mb-3">
                    @foreach (var error in ViewData.ModelState[string.Empty]!.Errors)
                    {
                        <p class="mb-0"><i class="bi bi-exclamation-circle me-1"></i>@error.ErrorMessage</p>
                    }
                </div>
            }
            <div class="d-flex align-items-center my-3">
                <hr class="flex-grow-1" style="border-color: var(--sw-border);" />
                <span class="mx-2 text-muted small">or</span>
                <hr class="flex-grow-1" style="border-color: var(--sw-border);" />
            </div>

            <button type="submit" class="btn btn-primary w-100 py-2">
                Sign In
            </button>

            <p class="text-center text-muted small mt-4 mb-0">
                Don't have an account?
                <a asp-action="Register" class="text-primary text-decoration-none">Sign up</a>
            </p>

        </form>

        <div class="d-flex align-items-center my-3">
            <hr class="flex-grow-1" style="border-color: var(--sw-border);" />
            <span class="mx-2 text-muted small">or</span>
            <hr class="flex-grow-1" style="border-color: var(--sw-border);" />
        </div>

        <form asp-controller="Account" asp-action="ExternalLogin" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="provider" value="Google" />
            <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
            <button type="submit" class="btn w-100 sw-google-btn">
                <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg"
                     width="18" height="18" class="me-2" />
                Continue with Google
            </button>
        </form>
    </div>
</div>