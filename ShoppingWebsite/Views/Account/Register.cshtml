@model ShoppingWebsite.ViewModels.Account.RegisterVM
@{
    ViewData["Title"] = "Register";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="min-vh-100 d-flex align-items-center justify-content-center py-5">
    <div class="sw-auth-card">
        <div class="text-center mb-4">
            <i class="bi bi-bag-heart-fill text-primary fs-1"></i>
            <h2 class="fw-bold mt-2">Create account</h2>
            <p class="text-muted small">Join ShopWave and start shopping</p>
        </div>

        <form asp-action="Register" method="post">
            @Html.AntiForgeryToken()

            <div class="sw-field mb-3">
                <label asp-for="FullName" class="form-label small text-muted"></label>
                <input asp-for="FullName" class="form-control sw-form-control" placeholder="John Doe" />
                <span asp-validation-for="FullName" class="field-error"></span>
            </div>

            <div class="sw-field mb-3">
                <label asp-for="Email" class="form-label small text-muted"></label>
                <input asp-for="Email" class="form-control sw-form-control" placeholder="you@example.com" />
                <span asp-validation-for="Email" class="field-error"></span>
            </div>

            <div class="sw-field mb-3">
                <label asp-for="Password" class="form-label small text-muted"></label>
                <input asp-for="Password" class="form-control sw-form-control" placeholder="••••••••" />
                <span asp-validation-for="Password" class="field-error"></span>
            </div>

            <div class="sw-field mb-4">
                <label asp-for="ConfirmPassword" class="form-label small text-muted"></label>
                <input asp-for="ConfirmPassword" class="form-control sw-form-control" placeholder="••••••••" />
                <span asp-validation-for="ConfirmPassword" class="field-error"></span>
            </div>


            <div class="d-flex align-items-center my-3">
                <hr class="flex-grow-1" style="border-color: var(--sw-border);" />
                <span class="mx-2 text-muted small">or</span>
                <hr class="flex-grow-1" style="border-color: var(--sw-border);" />
            </div>

            <button type="submit" class="btn btn-primary w-100 py-2">
                Create Account
            </button>

            <p class="text-center text-muted small mt-4 mb-0">
                Already have an account?
                <a asp-action="Login" class="text-primary text-decoration-none">Sign in</a>
            </p>
        </form>
        <div class="d-flex align-items-center my-3">
            <hr class="flex-grow-1" style="border-color: var(--sw-border);" />
            <span class="mx-2 text-muted small">or</span>
            <hr class="flex-grow-1" style="border-color: var(--sw-border);" />
        </div>

        <form asp-controller="Account" asp-action="ExternalLogin" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="provider" value="Google" />
            <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
            <button type="submit" class="btn w-100 sw-google-btn">
                <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg"
                     width="18" height="18" class="me-2" />
                Continue with Google
            </button>
        </form>
    </div>
</div>