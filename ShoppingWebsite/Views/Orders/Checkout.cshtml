@model ShoppingWebsite.Models.ViewModels.Orders.CheckoutVM
@{
    ViewData["Title"] = "Checkout";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <h4 class="fw-700 mb-4">
        <i class="bi bi-lock me-2 text-primary"></i>Checkout
    </h4>

    @if (!ViewData.ModelState.IsValid && ViewData.ModelState
        .Any(x => x.Key == string.Empty && x.Value!.Errors.Count > 0))
    {
        <div class="alert sw-alert-danger d-flex align-items-center gap-2 mb-4">
            <i class="bi bi-exclamation-circle-fill"></i>
            <span>
                @foreach (var error in ViewData.ModelState[string.Empty]!.Errors)
                {
                    @error.ErrorMessage
                }
            </span>
        </div>
    }

    <form asp-action="Checkout" method="post">
        @Html.AntiForgeryToken()
        @if (!Model.SavedAddresses.Any())
        {
            <input type="hidden" name="UseNewAddress" value="true" />
        }

        <div class="row g-4">

            <!-- Left — Address -->
            <div class="col-lg-7">
                <div class="sw-card p-4 mb-4">
                    <h6 class="fw-700 text-uppercase mb-3"
                        style="font-size: 0.75rem; letter-spacing: 1px; color: var(--sw-muted);">
                        Shipping Address
                    </h6>

                    <!-- Saved Addresses -->
                    @if (Model.SavedAddresses.Any())
                    {
                        <div class="mb-3">
                            @foreach (var address in Model.SavedAddresses)
                            {
                                <label class="sw-address-option @(address.IsDefault ? "active" : "")">
                                    <input type="radio"
                                           name="SelectedAddressId"
                                           value="@address.AddressId"
                                           @(address.IsDefault ? "checked" : "")
                                           onchange="toggleNewAddress(false)" />
                                    <div class="ms-2">
                                        <p class="mb-0 fw-600 small">@address.Street</p>
                                        <p class="mb-0 text-muted small">@address.City, @address.Country @address.Zip</p>
                                    </div>
                                    @if (address.IsDefault)
                                    {
                                        <span class="ms-auto sw-stock-badge sw-badge-in">Default</span>
                                    }
                                </label>
                            }
                        </div>

                        <!-- Toggle new address -->
                        <label class="sw-address-option" id="newAddressToggle">
                            <input type="radio"
                                   name="UseNewAddress"
                                   value="true"
                                   onchange="toggleNewAddress(true)" />
                            <div class="ms-2">
                                <p class="mb-0 fw-600 small">Use a new address</p>
                            </div>
                        </label>
                    }

                    <!-- New Address Form -->
                    <div id="newAddressForm" class="mt-3"
                         style="display: @(Model.SavedAddresses.Any() ? "none" : "block")">

                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="sw-field">
                                    <label asp-for="NewAddress.Country" class="form-label small text-muted"></label>
                                    <input asp-for="NewAddress.Country" class="form-control sw-form-control" placeholder="Egypt" />
                                    <span asp-validation-for="NewAddress.Country" class="field-error"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="sw-field">
                                    <label asp-for="NewAddress.City" class="form-label small text-muted"></label>
                                    <input asp-for="NewAddress.City" class="form-control sw-form-control" placeholder="Cairo" />
                                    <span asp-validation-for="NewAddress.City" class="field-error"></span>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="sw-field">
                                    <label asp-for="NewAddress.Street" class="form-label small text-muted"></label>
                                    <input asp-for="NewAddress.Street" class="form-control sw-form-control" placeholder="123 Main St" />
                                    <span asp-validation-for="NewAddress.Street" class="field-error"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="sw-field">
                                    <label asp-for="NewAddress.Zip" class="form-label small text-muted"></label>
                                    <input asp-for="NewAddress.Zip" class="form-control sw-form-control" placeholder="12345" />
                                    <span asp-validation-for="NewAddress.Zip" class="field-error"></span>
                                </div>
                            </div>
                            <div class="col-md-6 d-flex align-items-center gap-3 mt-2">
                                <div class="form-check">
                                    <input asp-for="NewAddress.SaveAddress" class="form-check-input" />
                                    <label asp-for="NewAddress.SaveAddress" class="form-check-label small text-muted">Save address</label>
                                </div>
                                <div class="form-check">
                                    <input asp-for="NewAddress.IsDefault" class="form-check-input" />
                                    <label asp-for="NewAddress.IsDefault" class="form-check-label small text-muted">Set as default</label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right — Order Summary -->
            <div class="col-lg-5">
                <div class="sw-card p-4">
                    <h6 class="fw-700 text-uppercase mb-3"
                        style="font-size: 0.75rem; letter-spacing: 1px; color: var(--sw-muted);">
                        Order Summary
                    </h6>

                    @foreach (var item in Model.Cart.Items)
                    {
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <img src="@item.ImageUrl"
                                 alt="@item.ProductName"
                                 style="width: 48px; height: 48px; object-fit: cover; border-radius: 8px;" />
                            <div class="flex-grow-1">
                                <p class="mb-0 small fw-600">@item.ProductName</p>
                                <p class="mb-0 text-muted small">x@item.Quantity</p>
                            </div>
                            <span class="fw-600 small">$@item.LineTotal.ToString("0.00")</span>
                        </div>
                    }

                    <hr style="border-color: var(--sw-border);" />

                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted small">Subtotal</span>
                        <span class="fw-600">$@Model.Cart.Total.ToString("0.00")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-muted small">Shipping</span>
                        <span class="text-success fw-600">Free</span>
                    </div>

                    <hr style="border-color: var(--sw-border);" />

                    <div class="d-flex justify-content-between mb-4">
                        <span class="fw-700">Total</span>
                        <span class="fw-700 fs-5 text-primary">$@Model.Cart.Total.ToString("0.00")</span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-2 fw-600">
                        <i class="bi bi-bag-check me-2"></i>Place Order
                    </button>

                    <a asp-controller="Cart" asp-action="Index"
                       class="btn btn-outline-secondary w-100 py-2 mt-2">
                        <i class="bi bi-arrow-left me-2"></i>Back to Cart
                    </a>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        function toggleNewAddress(show) {
            const form = document.getElementById('newAddressForm');
            const toggle = document.getElementById('newAddressToggle');
            form.style.display = show ? 'block' : 'none';

            if (!show) {
                // Reset UseNewAddress to false
                const hidden = document.querySelector('input[name="UseNewAddress"][type="radio"]');
                if (hidden) hidden.checked = false;
            }

            // Update toggle card style
            toggle.classList.toggle('active', show);
        }
    </script>
}