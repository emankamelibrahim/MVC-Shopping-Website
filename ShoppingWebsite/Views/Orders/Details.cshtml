@model ShoppingWebsite.Models.ViewModels.Orders.OrderDetailsVM
@{
    ViewData["Title"] = $"Order {Model.OrderNumber}";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-3">
        <div>
            <h4 class="fw-700 mb-1">
                <i class="bi bi-box me-2 text-primary"></i>@Model.OrderNumber
            </h4>
            <p class="text-muted small mb-0">
                Placed on @Model.OrderDate.ToString("MMMM dd, yyyy 'at' hh:mm tt")
            </p>
        </div>
        <div class="d-flex align-items-center gap-3">
            <span class="sw-status-badge @Model.StatusClass fs-6 px-3 py-2">
                @Model.StatusDisplay
            </span>
            @if (Model.Status == ShoppingWebsite.Data.Entities.OrderStatus.Pending)
            {
                <form asp-action="Cancel" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="orderId" value="@Model.OrderId" />
                    <button type="submit" class="btn btn-outline-danger btn-sm"
                            onclick="return confirm('Are you sure you want to cancel this order?')">
                        <i class="bi bi-x-circle me-1"></i>Cancel Order
                    </button>
                </form>
            }
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert sw-alert-success d-flex align-items-center gap-2 mb-4">
            <i class="bi bi-check-circle-fill"></i>
            <span>@TempData["Success"]</span>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert sw-alert-danger d-flex align-items-center gap-2 mb-4">
            <i class="bi bi-exclamation-circle-fill"></i>
            <span>@TempData["Error"]</span>
        </div>
    }

    <div class="row g-4">

        <!-- Order Items -->
        <div class="col-lg-8">
            <div class="sw-card p-4">
                <h6 class="fw-700 text-uppercase mb-3"
                    style="font-size: 0.75rem; letter-spacing: 1px; color: var(--sw-muted);">
                    Items Ordered
                </h6>

                @foreach (var item in Model.Items)
                {
                    <div class="d-flex align-items-center gap-3 mb-3 pb-3"
                         style="border-bottom: 1px solid var(--sw-border);">
                        <img src="@item.ImageUrl"
                             alt="@item.ProductName"
                             style="width: 60px; height: 60px; object-fit: cover; border-radius: 8px;" />
                        <div class="flex-grow-1">
                            <p class="mb-0 fw-600">@item.ProductName</p>
                            <p class="mb-0 text-muted small">
                                $@item.UnitPrice.ToString("0.00") x @item.Quantity
                            </p>
                        </div>
                        <span class="fw-700 text-primary">$@item.LineTotal.ToString("0.00")</span>
                    </div>
                }

                <div class="d-flex justify-content-between mt-2">
                    <span class="fw-700">Total</span>
                    <span class="fw-700 fs-5 text-primary">$@Model.TotalAmount.ToString("0.00")</span>
                </div>
            </div>
        </div>

        <!-- Sidebar Info -->
        <div class="col-lg-4">

            <!-- Shipping Address -->
            <div class="sw-card p-4 mb-3">
                <h6 class="fw-700 text-uppercase mb-3"
                    style="font-size: 0.75rem; letter-spacing: 1px; color: var(--sw-muted);">
                    Shipping Address
                </h6>
                <p class="text-muted small mb-0">
                    <i class="bi bi-geo-alt me-1 text-primary"></i>@Model.ShippingAddress
                </p>
            </div>

            <!-- Order Status Timeline -->
            <div class="sw-card p-4">
                <h6 class="fw-700 text-uppercase mb-3"
                    style="font-size: 0.75rem; letter-spacing: 1px; color: var(--sw-muted);">
                    Order Status
                </h6>
                <div class="sw-timeline">
                    @{
                        var statuses = new[] { "Pending", "Processing", "Shipped", "Delivered" };
                        var currentIndex = (int)Model.Status;
                        var isCancelled = Model.Status == ShoppingWebsite.Data.Entities.OrderStatus.Cancelled;
                    }

                    @if (isCancelled)
                    {
                        <div class="sw-timeline-item sw-timeline-cancelled">
                            <div class="sw-timeline-dot"></div>
                            <div class="sw-timeline-content">
                                <p class="mb-0 fw-600 small">Cancelled</p>
                            </div>
                        </div>
                    }
                    else
                    {
                        @for (int i = 0; i < statuses.Length; i++)
                        {
                            var isDone = i < currentIndex;
                            var isCurrent = i == currentIndex;
                            <div class="sw-timeline-item @(isDone ? "done" : "") @(isCurrent ? "current" : "")">
                                <div class="sw-timeline-dot"></div>
                                <div class="sw-timeline-content">
                                    <p class="mb-0 fw-600 small">@statuses[i]</p>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="mt-4">
        <a asp-action="Index" class="text-muted text-decoration-none small">
            <i class="bi bi-arrow-left me-1"></i>Back to Orders
        </a>
    </div>
</div>