@model ShoppingWebsite.Models.ViewModels.Orders.OrderListVM
@{
    ViewData["Title"] = "My Orders";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <h4 class="fw-700 mb-4">
        <i class="bi bi-box me-2 text-primary"></i>My Orders
    </h4>

    @if (!Model.Orders.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-box" style="font-size: 4rem; color: var(--sw-muted);"></i>
            <h5 class="mt-3 text-muted">No orders yet</h5>
            <a asp-controller="Catalog" asp-action="Index" class="btn btn-primary mt-3 px-5">
                Start Shopping
            </a>
        </div>
    }
    else
    {
        <div class="sw-card">
            <div class="table-responsive">
                <table class="table sw-table mb-0">
                    <thead>
                        <tr>
                            <th>Order #</th>
                            <th>Date</th>
                            <th>Items</th>
                            <th>Total</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model.Orders)
                        {
                            <tr>
                                <td class="fw-600">@order.OrderNumber</td>
                                <td class="text-muted small">@order.OrderDate.ToString("MMM dd, yyyy")</td>
                                <td class="text-muted small">@order.ItemCount items</td>
                                <td class="fw-600 text-primary">$@order.TotalAmount.ToString("0.00")</td>
                                <td>
                                    <span class="sw-status-badge @order.StatusClass">
                                        @order.StatusDisplay
                                    </span>
                                </td>
                                <td class="text-end">
                                    <a asp-action="Details" asp-route-id="@order.OrderId"
                                       class="btn btn-outline-primary btn-sm">
                                        <i class="bi bi-eye me-1"></i>View
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>