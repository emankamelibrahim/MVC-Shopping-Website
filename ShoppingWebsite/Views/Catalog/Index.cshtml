@model ShoppingWebsite.Models.ViewModels.Catalog.ProductListVM
@{
    ViewData["Title"] = "Catalog";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <div class="row g-4">

        <!-- Sidebar -->
        <div class="col-lg-3">
            <div class="sw-card p-3">
                <h6 class="fw-700 mb-3 text-muted text-uppercase" style="font-size:0.75rem; letter-spacing:1px;">
                    Categories
                </h6>

                <!-- All Products -->
                <a asp-action="Index"
                   asp-route-q="@Model.Search"
                   asp-route-sort="@Model.Sort"
                   class="d-flex justify-content-between align-items-center sw-cat-link @(Model.SelectedCategoryId == null ? "active" : "")">
                    <span>All Products</span>
                    <span class="sw-cat-count">@Model.AllProductsCount</span>
                </a>

                <hr style="border-color: var(--sw-border);" />

                <!-- Parent Categories -->
                @foreach (var parent in Model.Categories.Where(c => c.ParentCategoryId == null))
                {
                    <a asp-action="Index"
                       asp-route-categoryId="@parent.CategoryId"
                       asp-route-q="@Model.Search"
                       asp-route-sort="@Model.Sort"
                       class="d-flex justify-content-between align-items-center sw-cat-link @(Model.SelectedCategoryId == parent.CategoryId ? "active" : "")">
                        <span>@parent.Name</span>
                        <span class="sw-cat-count">@parent.ProductCount</span>
                    </a>

                    <!-- Sub Categories -->
                    @foreach (var sub in Model.Categories.Where(c => c.ParentCategoryId == parent.CategoryId))
                    {
                        <a asp-action="Index"
                           asp-route-categoryId="@sub.CategoryId"
                           asp-route-q="@Model.Search"
                           asp-route-sort="@Model.Sort"
                           class="d-flex justify-content-between align-items-center sw-cat-link sw-cat-sub @(Model.SelectedCategoryId == sub.CategoryId ? "active" : "")">
                            <span>@sub.Name</span>
                            <span class="sw-cat-count">@sub.ProductCount</span>
                        </a>
                    }
                }
            </div>
        </div>

        <!-- Main Content -->
        <div class="col-lg-9">

            <!-- Toolbar -->
            <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
                <div>
                    <h5 class="fw-700 mb-0">
                        @if (!string.IsNullOrEmpty(Model.Search))
                        {
                            <span>Results for "<span class="text-primary">@Model.Search</span>"</span>
                        }
                        else if (Model.SelectedCategoryId != null)
                        {
                            <span>@Model.Categories.FirstOrDefault(c => c.CategoryId == Model.SelectedCategoryId)?.Name</span>
                        }
                        else
                        {
                            <span>All Products</span>
                        }
                    </h5>
                    <p class="text-muted small mb-0">@Model.TotalCount products found</p>
                </div>

                <!-- Sort -->
                <div class="d-flex align-items-center gap-2">
                    <span class="text-muted small">Sort by:</span>
                    <div class="btn-group btn-group-sm">
                        <a asp-action="Index"
                           asp-route-categoryId="@Model.SelectedCategoryId"
                           asp-route-q="@Model.Search"
                           asp-route-sort=""
                           class="btn @(string.IsNullOrEmpty(Model.Sort) ? "btn-primary" : "btn-outline-secondary")">
                            A-Z
                        </a>
                        <a asp-action="Index"
                           asp-route-categoryId="@Model.SelectedCategoryId"
                           asp-route-q="@Model.Search"
                           asp-route-sort="newest"
                           class="btn @(Model.Sort == "newest" ? "btn-primary" : "btn-outline-secondary")">
                            Newest
                        </a>
                        <a asp-action="Index"
                           asp-route-categoryId="@Model.SelectedCategoryId"
                           asp-route-q="@Model.Search"
                           asp-route-sort="price_asc"
                           class="btn @(Model.Sort == "price_asc" ? "btn-primary" : "btn-outline-secondary")">
                            Price ↑
                        </a>
                        <a asp-action="Index"
                           asp-route-categoryId="@Model.SelectedCategoryId"
                           asp-route-q="@Model.Search"
                           asp-route-sort="price_desc"
                           class="btn @(Model.Sort == "price_desc" ? "btn-primary" : "btn-outline-secondary")">
                            Price ↓
                        </a>
                    </div>
                </div>
            </div>

            <!-- Product Grid -->
            @if (!Model.Products.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-search" style="font-size:3rem; color: var(--sw-muted);"></i>
                    <h5 class="mt-3 text-muted">No products found</h5>
                    <a asp-action="Index" class="btn btn-outline-primary mt-2">Clear filters</a>
                </div>
            }
            else
            {
                <div class="row g-4">
                    @foreach (var product in Model.Products)
                    {
                        <div class="col-sm-6 col-xl-4">
                            <div class="sw-card h-100">
                                <img src="@product.ImageUrl"
                                     alt="@product.Name"
                                     class="sw-card-img" />
                                <div class="sw-card-body">
                                    <div class="d-flex justify-content-between align-items-start mb-1">
                                        <p class="sw-card-title mb-0 me-2">@product.Name</p>
                                        @if (product.StockQuantity > 10)
                                        {
                                            <span class="sw-stock-badge sw-badge-in text-nowrap">In Stock</span>
                                        }
                                        else if (product.StockQuantity > 0)
                                        {
                                            <span class="sw-stock-badge sw-badge-low text-nowrap">Low Stock</span>
                                        }
                                        else
                                        {
                                            <span class="sw-stock-badge sw-badge-out text-nowrap">Out of Stock</span>
                                        }
                                    </div>
                                    <p class="text-muted small mb-2">@product.CategoryName</p>
                                    <div class="d-flex justify-content-between align-items-center mt-2">
                                        <span class="sw-card-price">$@product.Price.ToString("0.00")</span>
                                        <a asp-action="Details"
                                           asp-route-id="@product.ProductId"
                                           class="btn btn-primary btn-sm px-3">
                                            <i class="bi bi-eye me-1"></i>View
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Pagination -->
                @if (Model.TotalPages > 1)
                {
                    <div class="d-flex justify-content-center mt-5">
                        <nav>
                            <ul class="pagination sw-pagination">

                                <!-- Prev -->
                                <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                                    <a class="page-link" asp-action="Index"
                                       asp-route-categoryId="@Model.SelectedCategoryId"
                                       asp-route-q="@Model.Search"
                                       asp-route-sort="@Model.Sort"
                                       asp-route-page="@(Model.CurrentPage - 1)">
                                        <i class="bi bi-chevron-left"></i>
                                    </a>
                                </li>

                                @for (int i = 1; i <= Model.TotalPages; i++)
                                {
                                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                        <a class="page-link" asp-action="Index"
                                           asp-route-categoryId="@Model.SelectedCategoryId"
                                           asp-route-q="@Model.Search"
                                           asp-route-sort="@Model.Sort"
                                           asp-route-page="@i">@i</a>
                                    </li>
                                }

                                <!-- Next -->
                                <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                                    <a class="page-link" asp-action="Index"
                                       asp-route-categoryId="@Model.SelectedCategoryId"
                                       asp-route-q="@Model.Search"
                                       asp-route-sort="@Model.Sort"
                                       asp-route-page="@(Model.CurrentPage + 1)">
                                        <i class="bi bi-chevron-right"></i>
                                    </a>
                                </li>

                            </ul>
                        </nav>
                    </div>
                }
            }
        </div>
    </div>
</div>