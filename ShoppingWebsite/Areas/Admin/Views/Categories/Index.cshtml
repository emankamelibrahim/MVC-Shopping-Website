@model ShoppingWebsite.Models.ViewModels.Admin.CategoryListVM
@{
    ViewData["Title"] = "Categories";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <p class="text-muted mb-0">@Model.Categories.Count() categories total</p>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-2"></i>New Category
    </a>
</div>

<div class="sw-admin-table">
    <div class="table-responsive">
        <table class="table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Name</th>
                    <th>Parent</th>
                    <th>Products</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cat in Model.Categories)
                {
                    <tr>
                        <td class="text-muted small">@cat.CategoryId</td>
                        <td class="fw-600">@cat.Name</td>
                        <td class="text-muted small">@(cat.ParentName ?? "—")</td>
                        <td>
                            <span class="sw-status-badge sw-status-processing">
                                @cat.ProductCount
                            </span>
                        </td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@cat.CategoryId"
                               class="btn btn-outline-secondary btn-sm me-1">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form asp-action="Delete" asp-route-id="@cat.CategoryId"
                                  method="post" class="d-inline"
                                  onsubmit="return confirm('Delete @cat.Name?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-danger btn-sm">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>