@model ShoppingWebsite.Models.ViewModels.Admin.CategoryFormVM
@{
    var isEdit = Model.CategoryId != 0;
    ViewData["Title"] = isEdit ? "Edit Category" : "New Category";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="mb-4">
    <a asp-action="Index" class="text-muted text-decoration-none small">
        <i class="bi bi-arrow-left me-1"></i>Back to Categories
    </a>
</div>

<div class="sw-admin-form-card">
    <form asp-action="@(isEdit ? "Edit" : "Create")" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="CategoryId" />

        <div class="sw-field mb-3">
            <label asp-for="Name" class="form-label small text-muted"></label>
            <input asp-for="Name" class="form-control sw-form-control" placeholder="Category name" />
            <span asp-validation-for="Name" class="field-error"></span>
        </div>

        <div class="sw-field mb-4">
            <label asp-for="ParentCategoryId" class="form-label small text-muted">Parent Category (optional)</label>
            <select asp-for="ParentCategoryId" class="form-select sw-form-control">
                <option value="">— None (top-level) —</option>
                @foreach (var option in Model.ParentOptions)
                {
                    <option value="@option.CategoryId">@option.Name</option>
                }
            </select>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary px-4">
                <i class="bi bi-check-lg me-2"></i>@(isEdit ? "Save Changes" : "Create Category")
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
        </div>
    </form>
</div>