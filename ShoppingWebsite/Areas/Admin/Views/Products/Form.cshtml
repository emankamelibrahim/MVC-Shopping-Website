@model ShoppingWebsite.Models.ViewModels.Admin.ProductFormVM
@{
    var isEdit = Model.ProductId != 0;
    ViewData["Title"] = isEdit ? "Edit Product" : "New Product";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="mb-4">
    <a asp-action="Index" class="text-muted text-decoration-none small">
        <i class="bi bi-arrow-left me-1"></i>Back to Products
    </a>
</div>

<div class="sw-admin-form-card">
    <form asp-action="@(isEdit ? "Edit" : "Create")" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="ProductId" />

        <div class="row g-3">
            <div class="col-md-8">
                <div class="sw-field">
                    <label asp-for="Name" class="form-label small text-muted"></label>
                    <input asp-for="Name" class="form-control sw-form-control" placeholder="Product name" />
                    <span asp-validation-for="Name" class="field-error"></span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="sw-field">
                    <label asp-for="SKU" class="form-label small text-muted"></label>
                    <input asp-for="SKU" class="form-control sw-form-control" placeholder="SKU-001" />
                    <span asp-validation-for="SKU" class="field-error"></span>
                </div>
            </div>

            <div class="col-md-6">
                <div class="sw-field">
                    <label asp-for="Price" class="form-label small text-muted"></label>
                    <input asp-for="Price" type="number" step="0.01"
                           class="form-control sw-form-control" placeholder="0.00" />
                    <span asp-validation-for="Price" class="field-error"></span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="sw-field">
                    <label asp-for="StockQuantity" class="form-label small text-muted"></label>
                    <input asp-for="StockQuantity" type="number"
                           class="form-control sw-form-control" placeholder="0" />
                    <span asp-validation-for="StockQuantity" class="field-error"></span>
                </div>
            </div>

            <div class="col-12">
                <div class="sw-field">
                    <select asp-for="CategoryId" class="form-select sw-form-control">
                        <option value="">— Select category —</option>
                        @foreach (var opt in Model.CategoryOptions)
                        {
                            <option value="@opt.CategoryId">@opt.Name</option>
                        }
                    </select>
                    <span asp-validation-for="CategoryId" class="field-error"></span>
                </div>
            </div>

            <div class="col-12">
                <div class="sw-field">
                    <label class="form-label small text-muted">Product Image</label>

                    <!-- File upload -->
                    <input asp-for="ImageFile" type="file"
                           class="form-control sw-form-control mb-2"
                           accept=".jpg,.jpeg,.png,.webp" />

                    <!-- OR URL fallback -->
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <hr class="flex-grow-1" style="border-color: var(--sw-border);" />
                        <span class="text-muted small">or paste URL</span>
                        <hr class="flex-grow-1" style="border-color: var(--sw-border);" />
                    </div>

                    <input asp-for="ImageUrl" class="form-control sw-form-control"
                           placeholder="https://..." />
                </div>

                <!-- Preview -->
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" alt="Preview"
                         class="mt-2 rounded"
                         style="height: 80px; object-fit: cover;" />
                }
            </div>

            <div class="col-12">
                <div class="sw-field">
                    <label asp-for="Description" class="form-label small text-muted"></label>
                    <textarea asp-for="Description" class="form-control sw-form-control"
                              rows="3" placeholder="Product description..."></textarea>
                </div>
            </div>

            <div class="col-12">
                <div class="form-check">
                    <input asp-for="IsActive" class="form-check-input" />
                    <label asp-for="IsActive" class="form-check-label small text-muted">Active (visible in store)</label>
                </div>
            </div>
        </div>

        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary px-4">
                <i class="bi bi-check-lg me-2"></i>@(isEdit ? "Save Changes" : "Create Product")
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
        </div>
    </form>
</div>