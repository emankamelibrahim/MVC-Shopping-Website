@model ShoppingWebsite.Models.ViewModels.Admin.ProductListAdminVM
@{
    ViewData["Title"] = "Products";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <p class="text-muted mb-0">@Model.Products.Count() products total</p>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-2"></i>New Product
    </a>
</div>

<div class="sw-admin-table">
    <div class="table-responsive">
        <table class="table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Name</th>
                    <th>SKU</th>
                    <th>Category</th>
                    <th>Price</th>
                    <th>Stock</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model.Products)
                {
                    <tr>
                        <td class="text-muted small">@p.ProductId</td>
                        <td class="fw-600">@p.Name</td>
                        <td class="text-muted small">@p.SKU</td>
                        <td class="text-muted small">@p.CategoryName</td>
                        <td class="text-primary fw-600">$@p.Price.ToString("0.00")</td>
                        <td>
                            @if (p.StockQuantity > 10)
                            {
                                <span class="sw-status-badge sw-status-delivered">@p.StockQuantity</span>
                            }
                            else if (p.StockQuantity > 0)
                            {
                                <span class="sw-status-badge sw-status-pending">@p.StockQuantity</span>
                            }
                            else
                            {
                                <span class="sw-status-badge sw-status-cancelled">0</span>
                            }
                        </td>
                        <td>
                            @if (p.IsActive)
                            {
                                <span class="sw-status-badge sw-status-delivered">Active</span>
                            }
                            else
                            {
                                <span class="sw-status-badge sw-status-cancelled">Inactive</span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@p.ProductId"
                               class="btn btn-outline-secondary btn-sm me-1">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form asp-action="ToggleActive" asp-route-id="@p.ProductId"
                                  method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit"
                                        class="btn btn-sm me-1 @(p.IsActive ? "btn-outline-warning" : "btn-outline-success")"
                                        title="@(p.IsActive ? "Deactivate" : "Activate")">
                                    <i class="bi @(p.IsActive ? "bi-eye-slash" : "bi-eye")"></i>
                                </button>
                            </form>
                            <form asp-action="Delete" asp-route-id="@p.ProductId"
                                  method="post" class="d-inline"
                                  onsubmit="return confirm('Delete @p.Name?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-danger btn-sm">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>