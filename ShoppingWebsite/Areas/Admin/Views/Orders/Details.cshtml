@model ShoppingWebsite.Models.ViewModels.Admin.AdminOrderDetailsVM
@{
    ViewData["Title"] = $"Order {Model.OrderNumber}";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="mb-4">
    <a asp-action="Index" class="text-muted text-decoration-none small">
        <i class="bi bi-arrow-left me-1"></i>Back to Orders
    </a>
</div>

<div class="row g-4">

    <!-- Order Items -->
    <div class="col-lg-8">
        <div class="sw-admin-table mb-4">
            <div class="d-flex justify-content-between align-items-center p-3"
                 style="border-bottom: 1px solid var(--sw-border);">
                <div>
                    <h6 class="fw-700 mb-0">@Model.OrderNumber</h6>
                    <p class="text-muted small mb-0">
                        @Model.OrderDate.ToString("MMMM dd, yyyy 'at' hh:mm tt")
                    </p>
                </div>
                <span class="sw-status-badge @Model.StatusClass fs-6 px-3 py-2">
                    @Model.StatusDisplay
                </span>
            </div>
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Unit Price</th>
                            <th>Qty</th>
                            <th class="text-end">Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <img src="@item.ImageUrl" alt="@item.ProductName"
                                             style="width:40px;height:40px;object-fit:cover;border-radius:6px;" />
                                        <span class="fw-600 small">@item.ProductName</span>
                                    </div>
                                </td>
                                <td class="text-muted small">$@item.UnitPrice.ToString("0.00")</td>
                                <td class="text-muted small">@item.Quantity</td>
                                <td class="text-end fw-600 text-primary">$@item.LineTotal.ToString("0.00")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="3" class="text-end fw-700">Total</td>
                            <td class="text-end fw-700 text-primary fs-6">
                                $@Model.TotalAmount.ToString("0.00")
                            </td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>

    <!-- Sidebar -->
    <div class="col-lg-4">

        <!-- Customer Info -->
        <div class="sw-admin-form-card mb-3" style="max-width:100%;">
            <h6 class="fw-700 text-uppercase mb-3"
                style="font-size:0.72rem;letter-spacing:1px;color:var(--sw-muted);">
                Customer
            </h6>
            <p class="fw-600 mb-1">@Model.CustomerName</p>
            <p class="text-muted small mb-0">@Model.CustomerEmail</p>
        </div>

        <!-- Shipping Address -->
        <div class="sw-admin-form-card mb-3" style="max-width:100%;">
            <h6 class="fw-700 text-uppercase mb-3"
                style="font-size:0.72rem;letter-spacing:1px;color:var(--sw-muted);">
                Shipping Address
            </h6>
            <p class="text-muted small mb-0">
                <i class="bi bi-geo-alt me-1 text-primary"></i>@Model.ShippingAddress
            </p>
        </div>

        <!-- Update Status -->
        <div class="sw-admin-form-card" style="max-width:100%;">
            <h6 class="fw-700 text-uppercase mb-3"
                style="font-size:0.72rem;letter-spacing:1px;color:var(--sw-muted);">
                Update Status
            </h6>
            <form asp-action="UpdateStatus" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="orderId" value="@Model.OrderId" />
                <div class="sw-field mb-3">
                    <select name="status" class="form-select sw-form-control">
                        <!option value="0" @(Model.Status == ShoppingWebsite.Data.Entities.OrderStatus.Pending ? "selected" : "")>Pending</!option>
                        <!option value="1" @(Model.Status == ShoppingWebsite.Data.Entities.OrderStatus.Processing ? "selected" : "")>Processing</!option>
                        <!option value="2" @(Model.Status == ShoppingWebsite.Data.Entities.OrderStatus.Shipped ? "selected" : "")>Shipped</!option>
                        <!option value="3" @(Model.Status == ShoppingWebsite.Data.Entities.OrderStatus.Delivered ? "selected" : "")>Delivered</!option>
                        <!option value="4" @(Model.Status == ShoppingWebsite.Data.Entities.OrderStatus.Cancelled ? "selected" : "")>Cancelled</!option>
                    </select>
                </div>
                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-check-lg me-2"></i>Update Status
                </button>
            </form>
        </div>
    </div>
</div>