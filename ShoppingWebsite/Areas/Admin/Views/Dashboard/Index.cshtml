@model ShoppingWebsite.Models.ViewModels.Admin.DashboardVM
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<!-- Stat Cards -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="sw-stat-card">
            <div class="sw-stat-icon blue"><i class="bi bi-box-seam"></i></div>
            <div>
                <div class="sw-stat-value">@Model.TotalProducts</div>
                <div class="sw-stat-label">Active Products</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="sw-stat-card">
            <div class="sw-stat-icon green"><i class="bi bi-receipt"></i></div>
            <div>
                <div class="sw-stat-value">@Model.TotalOrders</div>
                <div class="sw-stat-label">Total Orders</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="sw-stat-card">
            <div class="sw-stat-icon purple"><i class="bi bi-people"></i></div>
            <div>
                <div class="sw-stat-value">@Model.TotalCustomers</div>
                <div class="sw-stat-label">Customers</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="sw-stat-card">
            <div class="sw-stat-icon yellow"><i class="bi bi-currency-dollar"></i></div>
            <div>
                <div class="sw-stat-value">$@Model.TotalRevenue.ToString("0.00")</div>
                <div class="sw-stat-label">Total Revenue</div>
            </div>
        </div>
    </div>
</div>

<!-- Alerts Row -->
<div class="row g-3 mb-4">
    <div class="col-md-6">
        <div class="sw-stat-card">
            <div class="sw-stat-icon yellow"><i class="bi bi-clock"></i></div>
            <div>
                <div class="sw-stat-value">@Model.PendingOrders</div>
                <div class="sw-stat-label">Pending Orders</div>
            </div>
            <a asp-area="Admin" asp-controller="Orders" asp-action="Index"
               class="btn btn-outline-warning btn-sm ms-auto">View</a>
        </div>
    </div>
    <div class="col-md-6">
        <div class="sw-stat-card">
            <div class="sw-stat-icon purple"><i class="bi bi-exclamation-triangle"></i></div>
            <div>
                <div class="sw-stat-value">@Model.LowStockProducts</div>
                <div class="sw-stat-label">Low Stock Products</div>
            </div>
            <a asp-area="Admin" asp-controller="Products" asp-action="Index"
               class="btn btn-outline-warning btn-sm ms-auto">View</a>
        </div>
    </div>
</div>

<!-- Recent Orders -->
<div class="sw-admin-table">
    <div class="d-flex justify-content-between align-items-center p-3"
         style="border-bottom: 1px solid var(--sw-border);">
        <h6 class="fw-700 mb-0">Recent Orders</h6>
        <a asp-area="Admin" asp-controller="Orders" asp-action="Index"
           class="btn btn-outline-primary btn-sm">View All</a>
    </div>
    <div class="table-responsive">
        <table class="table">
            <thead>
                <tr>
                    <th>Order #</th>
                    <th>Customer</th>
                    <th>Date</th>
                    <th>Total</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model.RecentOrders)
                {
                    <tr>
                        <td class="fw-600">@order.OrderNumber</td>
                        <td>@order.CustomerName</td>
                        <td class="text-muted small">@order.OrderDate.ToString("MMM dd, yyyy")</td>
                        <td class="text-primary fw-600">$@order.TotalAmount.ToString("0.00")</td>
                        <td>
                            <span class="sw-status-badge @order.StatusClass">@order.StatusDisplay</span>
                        </td>
                        <td class="text-end">
                            <a asp-area="Admin" asp-controller="Orders"
                               asp-action="Details" asp-route-id="@order.OrderId"
                               class="btn btn-outline-secondary btn-sm">
                                <i class="bi bi-eye"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>